# GZCTF Autonomous CTF Solver - Configuration
# Fill in your credentials before the competition

# Platform URL (no trailing slash)
GZCTF_BASE_URL=http://your-gzctf-server:8080

# Account credentials
GZCTF_USERNAME=your_username
GZCTF_PASSWORD=your_password

# Game ID (integer) - set to 0 for auto-discovery (picks first available game)
GZCTF_GAME_ID=0

# Team name (if joining as team)
GZCTF_TEAM_NAME=AI_Solver

# Polling interval in seconds between challenge check cycles
POLL_INTERVAL=10

# Maximum flag submission attempts per challenge
MAX_ATTEMPTS=5

# Timeout for individual challenge solving (seconds)
CHALLENGE_TIMEOUT=1800

# ── Daemon v2: Non-blocking controls ──────────────────────────────
# If agent doesn't finish within this time, abandon and try next challenge
CTF_TASK_TIMEOUT_SECONDS=600
# Maximum retries per challenge before permanent skip
CTF_MAX_RETRIES_PER_CHALLENGE=4
# Base cooldown in seconds before retrying a failed challenge (escalates 2x per retry)
CTF_BASE_RETRY_COOLDOWN=60
# Maximum cooldown ceiling (seconds)
CTF_MAX_RETRY_COOLDOWN=1800

# Download directory for challenge attachments
ATTACHMENT_DIR=/tmp/ctf_attachments
